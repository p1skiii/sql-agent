# Copy this file to .env and edit the values you actually use.

# --------------------------------------------------------------------
# Model proxy
# --------------------------------------------------------------------
# Required by the backend runtime. The documented path assumes a local
# OpenAI-compatible proxy at http://localhost:4141/v1.
LLM_API_KEY=your-openai-compatible-key
LLM_BASE_URL=http://localhost:4141/v1

# Default runtime models.
SQL_AGENT_INTENT_MODEL=gpt-4o-mini
SQL_AGENT_SQL_MODEL=gpt-4o-mini

# --------------------------------------------------------------------
# Recommended database path: PostgreSQL
# --------------------------------------------------------------------
SQL_AGENT_DB_BACKEND=postgres
SQL_AGENT_DB_URL=postgresql+psycopg://sql_agent:sql_agent@127.0.0.1:15432/sql_agent_demo

# PostgreSQL schema and seed files. Keep these unless you know you need
# different fixtures.
SQL_AGENT_SCHEMA_PATH=./schema.sql
SQL_AGENT_SEED_PATH=./seed.sql
SQL_AGENT_OVERWRITE_DB=true

# --------------------------------------------------------------------
# SQLite fallback
# --------------------------------------------------------------------
# Use these only when you intentionally switch to SQLite fallback.
# SQL_AGENT_DB_BACKEND=sqlite
# SQL_AGENT_DB_PATH=./sandbox/sandbox.db

# --------------------------------------------------------------------
# Frontend -> backend adapter
# --------------------------------------------------------------------
# The frontend reads this when it needs to point /api/chat at a non-default
# backend address.
# SQL_AGENT_RUN_URL=http://127.0.0.1:8000/run

# --------------------------------------------------------------------
# Optional toggles
# --------------------------------------------------------------------
# SQL_AGENT_TOP_K=5
# SQL_AGENT_MAX_ROWS=20
# SQL_AGENT_ALLOW_TRACE=false
# SQL_AGENT_SELFCHECK=false
# SQL_AGENT_LANGUAGE=en
# SQL_AGENT_ALLOW_WRITE=false
# SQL_AGENT_REQUIRE_WHERE=true
# SQL_AGENT_DRY_RUN_DEFAULT=true
# SQL_AGENT_ALLOW_FORCE=false
