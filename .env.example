# Copy this file to .env and fill in the values

# Copy this file to .env and fill in the values

# Required: primary API key for ChatOpenAI-compatible provider
LLM_API_KEY=sk-xxx

# Optional: override base URL (e.g., https://openrouter.ai/api/v1 or your gateway)
LLM_BASE_URL=https://api.openai.com/v1

# Model names passed directly to ChatOpenAI
SQL_AGENT_INTENT_MODEL=gpt-4o-mini
SQL_AGENT_SQL_MODEL=gpt-4o-mini

# AgentConfig toggles (all SQL_AGENT_* map directly to AgentConfig fields)
# SQL_AGENT_TOP_K=5
# SQL_AGENT_MAX_ROWS=20
# SQL_AGENT_ALLOW_TRACE=false
# SQL_AGENT_DB_PATH=./sandbox/sandbox.db
# SQL_AGENT_SCHEMA_PATH=./schema.sql
# SQL_AGENT_SEED_PATH=./seed.sql
# SQL_AGENT_OVERWRITE_DB=false
# SQL_AGENT_SELFCHECK=false
# SQL_AGENT_LANGUAGE=en
